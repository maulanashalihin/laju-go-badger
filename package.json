{
  "name": "laju-go-badger",
  "version": "0.0.1",
  "description": "Laju Go - High-performance SaaS boilerplate built with Go Fiber, Svelte 5, and Inertia.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:go": "air",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:go\"",
    "build": "vite build",
    "build:all": "vite build && go build -o laju-go ./cmd/laju-go",
    "build:go": "go build -o laju-go ./cmd/laju-go",
    "build:linux": "cross-env GOOS=linux GOARCH=amd64 go build -o laju-go ./cmd/laju-go",
    "deploy": "./scripts/deploy.sh",
    "serve": "go run ./cmd/laju-go",
    "db:reset": "rimraf ./data/badger",
    "verify": "templ generate && vite build && go build -o /dev/null ./cmd/laju-go && go vet ./..."
  },
  "author": "Maulana Shalihin",
  "license": "MIT",
  "dependencies": {
    "@inertiajs/svelte": "^3.0.0",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "lucide-svelte": "^1.0.1",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@inertiajs/vite": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "svelte": "^5.55.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
